@page "/"
@using FitControl.WebClient.Components.Layout

<link href="home.css" rel="stylesheet" />

<NavBar/>
    
    <!-- HERO SECTION -->
    <section class="hero">
        <div class="hero-bg" style="background-image: url('https://images.unsplash.com/photo-1685633224688-6a77675eb119?w=1800&h=1000&fit=crop&auto=format');"></div>
        <div class="hero-overlay"></div>
        <div class="hero-accent"></div>

        <div class="hero-content mb-5 mt-5">
            <div class="hero-badge">
                <span class="hero-pulse"></span>
                Software de Gestão de Ginásio
            </div>

            <h1 class="hero-title">
                FORJA O TEU
                <br />
                <span class="hero-title-orange">GINÁSIO.</span>
                <br />
                <span class="hero-title-outline">DOMINA OS</span>
                <br />
                RESULTADOS.
            </h1>

            <p class="hero-subtitle">
                A plataforma completa para gerir sócios, agendar aulas e acompanhar o crescimento do teu ginásio — tudo num só lugar.
            </p>

            <div class="hero-ctas">
                <a href="#" class="btn-primary">ENTRAR NO WEBSITE →</a>
                <a href="#" class="btn-secondary">VER DEMONSTRAÇÃO</a>
            </div>

            <div class="hero-stats">
                <div class="stat">
                    <span class="stat-value" style="color: #FF6B35;">100+</span>
                    <span class="stat-label">Sócios Ativos</span>
                </div>
                <div class="stat">
                    <span class="stat-value" style="color: #FFD60A;">99%</span>
                    <span class="stat-label">Taxa de Satisfação</span>
                </div>
                <div class="stat">
                    <span class="stat-value" style="color: #FF6B35;">100%</span>
                    <span class="stat-label">Tratamento de Excelência</span>
                </div>
                
            </div>
        </div>
    </section>

    <!-- FEATURES SECTION -->
    <section id="funcionalidades" class="features bg-dark">
        <div class="features-container">
            <div class="features-header">
                <p class="features-label">Funcionalidades</p>
                <h2 class="features-title text-white">
                    TUDO O QUE O TEU GINÁSIO
                    <span class="features-title-yellow"> PRECISA</span>
                </h2>
            </div>

            <div class="features-grid">
                <div class="feature-card">
                    <div class="feature-icon" style="background: rgba(255, 107, 53, 0.1);">
                        👥
                    </div>
                    <h3 class="feature-card-title">Gestão de Sócios</h3>
                    <p class="feature-card-desc">Controla inscrições, renovações e perfis dos teus sócios numa plataforma centralizada.</p>
                    <div class="feature-card-line" style="background: linear-gradient(to right, #FF6B35, transparent);"></div>
                </div>

                <div class="feature-card">
                    <div class="feature-icon" style="background: rgba(255, 214, 10, 0.1);">
                        ⏰
                    </div>
                    <h3 class="feature-card-title">Agendamento Inteligente</h3>
                    <p class="feature-card-desc">Marca aulas, treinos personalizados e espaços com um sistema automático e sem conflitos.</p>
                    <div class="feature-card-line" style="background: linear-gradient(to right, #FFD60A, transparent);"></div>
                </div>

                <div class="feature-card">
                    <div class="feature-icon" style="background: rgba(30, 144, 255, 0.1);">
                        📊
                    </div>
                    <h3 class="feature-card-title">Relatórios em Tempo Real</h3>
                    <p class="feature-card-desc">Acompanha receitas, frequência e evolução do ginásio com dashboards detalhados.</p>
                    <div class="feature-card-line" style="background: linear-gradient(to right, #1E90FF, transparent);"></div>
                </div>

                <div class="feature-card">
                    <div class="feature-icon" style="background: rgba(255, 107, 53, 0.1);">
                        💪
                    </div>
                    <h3 class="feature-card-title">Planos de Treino</h3>
                    <p class="feature-card-desc">Cria e distribui planos personalizados para cada sócio diretamente na plataforma.</p>
                    <div class="feature-card-line" style="background: linear-gradient(to right, #FF6B35, transparent);"></div>
                </div>
            </div>
        </div>
    </section>

    <!-- CTA BAND -->
    <section class="cta-band">
        <div class="cta-texture"></div>
        <div class="cta-container">
            <div>
                <h2 class="cta-title">
                    PRONTO PARA ELEVAR
                    <br />
                    O TEU GINÁSIO?
                </h2>
                <p class="cta-subtitle">Começa gratuitamente. Sem compromisso.</p>
            </div>
            <a href="#" class="btn-cta">COMEÇAR AGORA →</a>
        </div>
    </section>

    <Footer />

@code {
    protected override void OnInitialized()
    {
        // Inicializar página
    }
}