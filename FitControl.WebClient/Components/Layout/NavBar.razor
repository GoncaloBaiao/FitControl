@using FitControl.WebClient.Components.Layout
@implements IDisposable

<nav class="@NavbarClass">
    <div class="navbar-container">
        <div class="navbar-logo">
            <div class="navbar-logo-icon">🏋️
            </div>
            <span class="navbar-brand text-white">FITCONTROL</span>
        </div>

        <div class="navbar-links" style="margin: 30px 30px">
            <a href="#funcionalidades">Funcionalidades</a>
            <a href="#precos">Preços</a>
            <a href="#sobre">Sobre Nós</a>
            <a href="#contacto">Contacto</a>
        </div>

        <div style="display: flex; align-items: center; gap: 1rem; margin-left: 15px">
            <a href="#" class="navbar-cta">
                ENTRAR NA PLATAFORMA →
            </a>
            <button class="hamburger" @onclick="ToggleMobileMenu">
                @if (mobileMenuOpen)
                {
                    <span>✕</span>
                }
                else
                {
                    <span>☰</span>
                }
            </button>
        </div>
    </div>

    @if (mobileMenuOpen)
    {
        <div class="mobile-menu active">
            <a href="#funcionalidades" @onclick="() => mobileMenuOpen = false">Funcionalidades</a>
            <a href="#precos" @onclick="() => mobileMenuOpen = false">Preços</a>
            <a href="#sobre" @onclick="() => mobileMenuOpen = false">Sobre Nós</a>
            <a href="#contacto" @onclick="() => mobileMenuOpen = false">Contacto</a>
            <a href="#" class="navbar-cta" style="margin-top: 0.5rem;">ENTRAR NA PLATAFORMA →</a>
        </div>
    }
</nav>

@code {
    private bool mobileMenuOpen = false;

    private string NavbarClass => "navbar scrolled";

    private void ToggleMobileMenu()
    {
        mobileMenuOpen = !mobileMenuOpen;
    }

    void IDisposable.Dispose()
    {
        // Cleanup
    }
}